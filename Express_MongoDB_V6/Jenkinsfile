pipeline {
    agent any
    environment {
        PROJECT_DIR    = 'Express_MongoDB_V6'
        BACKEND_IMAGE  = 'modoundiaye/portfolio-backend'
        FRONTEND_IMAGE = 'modoundiaye/portfolio-frontend'
        SONAR_HOST_URL = 'http://sonarqube_portfolio:9000'
    }
    triggers { githubPush() }
    options {
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '5'))
    }
    stages {
        stage('Checkout') {
            steps {
                echo '=== ETAPE 1 : Checkout ==='
                checkout scm
                echo "=== Commit : ${env.GIT_COMMIT?.take(7)} ==="
            }
        }
        stage('Verification') {
            steps {
                echo '=== ETAPE 2 : Verification Docker ==='
                sh 'docker --version'
                sh 'docker compose version'
                sh 'docker ps --format "table {{.Names}}\\t{{.Status}}"'
            }
        }
        stage('Docker Build') {
            steps {
                dir("${PROJECT_DIR}") {
                    echo '=== ETAPE 3 : Docker Build ==='
                    sh 'docker compose build'
                    echo '=== Images construites ==='
                }
            }
        }
        stage('Deploiement') {
            steps {
                dir("${PROJECT_DIR}") {
                    echo '=== ETAPE 4 : Deploiement ==='
                    sh 'docker compose down || true'
                    sh 'docker compose up -d'
                    sh 'sleep 25'
                }
            }
        }
        stage('Health Check') {
            steps {
                echo '=== ETAPE 5 : Health Check ==='
                sh 'docker exec portfolio_backend wget --spider -q http://127.0.0.1:5000/api/health'
                echo '=== Application operationnelle ==='
            }
        }
        stage('Tests') {
            steps {
                echo '=== ETAPE 6 : Tests Jest (via docker exec) ==='
                sh 'docker exec portfolio_backend sh -c "cd /app && npm run test:coverage"'
                echo '=== Tests termines ==='
            }
        }
        stage('SonarQube Analysis') {
            steps {
                dir("${PROJECT_DIR}") {
                    echo '=== ETAPE 7 : Analyse SonarQube ==='
                    sh '''
                        docker run --rm \
                            --network portfolio-v6-pipeline_sonar_network \
                            -v "$(pwd):/usr/src" \
                            -w /usr/src \
                            sonarsource/sonar-scanner-cli \
                            -Dsonar.host.url=http://sonarqube_portfolio:9000 \
                            -Dsonar.token=9db3525e595688722b7c3bb54906a032 \
                            -Dsonar.projectKey=portfolio-v6 \
                            -Dsonar.projectName="Portfolio Express MongoDB V6" \
                            -Dsonar.sources=backend-expressJS,frontend-react/src \
                            -Dsonar.exclusions="**/node_modules/**,**/dist/**,**/coverage/**" \
                            -Dsonar.javascript.lcov.reportPaths=backend-expressJS/coverage/lcov.info \
                            -Dsonar.sourceEncoding=UTF-8
                    '''
                    echo '=== Analyse SonarQube terminee ==='
                }
            }
        }
        stage('Quality Gate') {
            steps {
                echo '=== ETAPE 8 : Quality Gate ==='
                timeout(time: 2, unit: 'MINUTES') {
                    sh '''
                        sleep 10
                        STATUS=$(docker exec sonarqube_portfolio curl -s -u 9db3525e595688722b7c3bb54906a032: \
                            "http://localhost:9000/api/qualitygates/project_status?projectKey=portfolio-v6" \
                            | grep -o '"status":"[^"]*"' | head -1 | cut -d'"' -f4)
                        echo "Quality Gate Status: $STATUS"
                        if [ "$STATUS" != "OK" ] && [ "$STATUS" != "NONE" ]; then
                            echo "Quality Gate FAILED"
                            exit 1
                        fi
                    '''
                }
                echo '=== Quality Gate : PASSED ==='
            }
        }
    }
    post {
        success { echo '=== PIPELINE REUSSI ===' }
        failure { echo '=== PIPELINE ECHOUE ===' }
        always {
            node {
                sh 'docker ps --format "table {{.Names}}\\t{{.Status}}" || true'
            }
            echo '=== Fin du pipeline ==='
        }
    }
}