pipeline {
    agent any

    environment {
        PROJECT_DIR = 'Express_MongoDB_V6'

        // Nom d utilisateur du compte Docker Hub de Modou NDIAYE.
        // Utilise pour tagger les images avant de les pousser.
        // Profil public : https://hub.docker.com/u/modoundiaye
        DOCKERHUB_USER = 'modoundiaye'

        // Nom complet de l image Docker du backend sur Docker Hub.
        // Format obligatoire Docker Hub : utilisateur/nom-image
        // Commande pour recuperer l image : docker pull modoundiaye/portfolio-backend
        BACKEND_IMAGE = 'modoundiaye/portfolio-backend'

        // Nom complet de l image Docker du frontend sur Docker Hub.
        // Commande pour recuperer l image : docker pull modoundiaye/portfolio-frontend
        FRONTEND_IMAGE = 'modoundiaye/portfolio-frontend'
    }

    // ----------------------------------------------------------------
    // triggers { }
    // ----------------------------------------------------------------
    // Definit les evenements qui declenchent automatiquement le pipeline.
    // Sans triggers, le pipeline ne se lance QUE manuellement (bouton "Build Now").
    triggers {

        // githubPush() : declenche le pipeline a chaque "git push" sur GitHub.
        // Mecanisme : GitHub envoie une requete HTTP (webhook) a Jenkins.
        // Jenkins recoit la notification et lance automatiquement le pipeline.
        // Prerequis :
        //   1. Plugin "GitHub Integration" installe dans Jenkins
        //   2. Webhook configure dans GitHub :
        //      Repository > Settings > Webhooks > Add webhook
        //      Payload URL : http://<adresse-jenkins>/github-webhook/
        //      Content type : application/json
        //      Events : Just the push event
        githubPush()
    }

    // ----------------------------------------------------------------
    // options { }
    // ----------------------------------------------------------------
    // Configure le comportement global du pipeline.
    // Ces options s appliquent a l ensemble du pipeline.
    options {
        timeout(time: 20, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '5'))
    }

    stages {
        // ── ÉTAPE 1 : Récupérer le code ──────────────────────────
        stage('Checkout') {
            steps {
                echo '=== Récupération du code source ==='
                checkout scm
                echo "=== Commit : ${env.GIT_COMMIT?.take(7)} ==="
            }
        }

        // ── ÉTAPE 2 : Vérifier Docker ─────────────────────────────
        stage('Verification') {
            steps {
                echo '=== Vérification Docker ==='
                sh 'docker --version'
                sh 'docker compose version'
                sh 'docker ps --format "table {{.Names}}\\t{{.Status}}"'
            }
        }

        // ── ÉTAPE 3 : Build Docker ────────────────────────────────
        stage('Docker Build') {
            steps {
                dir("${PROJECT_DIR}") {
                    echo '=== Construction des images Docker ==='
                    sh 'docker compose build'
                    echo '=== Images construites avec succès ==='
                }
            }
        }

        // ── ÉTAPE 4 : Déploiement ─────────────────────────────────
        stage('Deploiement') {
            steps {
                dir("${PROJECT_DIR}") {
                    echo '=== Arrêt des anciens conteneurs ==='
                    sh 'docker compose down || true'

                    echo '=== Démarrage des nouveaux conteneurs ==='
                    sh 'docker compose up -d'

                    echo '=== Attente démarrage MongoDB + Backend (25s) ==='
                    sh 'sleep 25'
                }
            }
        }
    }

    post {
        always {
            // Affichage des conteneurs dans les logs Jenkins
            sh 'docker ps --format "table {{.Names}}\\t{{.Status}}\\t{{.Ports}}" || true'
            echo '=== Fin du pipeline ==='

            // ENVOI DU MAIL (S'exécute à CHAQUE build)
            script {
                def statusIcon = currentBuild.currentResult == 'SUCCESS' ? '✅' : '❌'
                mail(
                    to:      'mn2243d@gmail.com',
                    subject: "${statusIcon} [Jenkins] Build #${env.BUILD_NUMBER} — Statut: ${currentBuild.currentResult}",
                    body:    """
Bonjour,

Le pipeline s'est terminé avec le statut : ${currentBuild.currentResult}

Détails du Job :
----------------------------------------------
Projet : ${env.JOB_NAME}
Build  : #${env.BUILD_NUMBER}
Durée  : ${currentBuild.durationString}
Logs   : ${env.BUILD_URL}
----------------------------------------------

=== Statut Docker final ===
${statusIcon} Vérifiez les logs pour plus de détails.
                    """
                )
            }
        }
        
        success {
            echo '''
==============================================
  PIPELINE REUSSI - Application deployee !
  Frontend : http://localhost
  API      : http://localhost:5000/api/health
==============================================
            '''
        }
        
        failure {
            echo '''
==============================================
  PIPELINE ECHOUE
  Consultez les logs ci-dessus
==============================================
            '''
        }
    }
}