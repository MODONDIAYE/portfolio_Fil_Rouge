pipeline {
    agent any

    environment {
        PROJECT_DIR = 'Express_MongoDB_V6'
    }

    options {
        timeout(time: 20, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '5'))
    }

    stages {

        // ── ÉTAPE 1 : Récupérer le code ──────────────────────────
        stage('Checkout') {
            steps {
                echo '=== Récupération du code source ==='
                checkout scm
                echo "=== Commit : ${env.GIT_COMMIT?.take(7)} ==="
            }
        }

        // ── ÉTAPE 2 : Vérifier Docker ─────────────────────────────
        stage('Verification') {
            steps {
                echo '=== Vérification Docker ==='
                sh 'docker --version'
                sh 'docker compose version'
                sh 'docker ps --format "table {{.Names}}\\t{{.Status}}"'
            }
        }

        // ── ÉTAPE 3 : Build Docker ────────────────────────────────
        // Node.js est dans les images Docker — pas besoin de l'installer ici
        stage('Docker Build') {
            steps {
                dir("${PROJECT_DIR}") {
                    echo '=== Construction des images Docker ==='
                    sh 'docker compose build'
                    echo '=== Images construites avec succès ==='
                }
            }
        }

        // ── ÉTAPE 4 : Déploiement ─────────────────────────────────
        stage('Deploiement') {
            steps {
                dir("${PROJECT_DIR}") {
                    echo '=== Arrêt des anciens conteneurs ==='
                    sh 'docker compose down || true'

                    echo '=== Démarrage des nouveaux conteneurs ==='
                    sh 'docker compose up -d'

                    echo '=== Attente démarrage MongoDB + Backend (25s) ==='
                    sh 'sleep 25'
                }
            }
        }

        // ── ÉTAPE 5 : Health Check ────────────────────────────────
        stage('Health Check') {
            steps {
                echo '=== Test API Backend ==='
                sh 'curl -f http://localhost:5000/api/health'

                echo '=== Test Frontend ==='
                sh 'curl -f -s -o /dev/null -w "HTTP Status: %{http_code}" http://localhost:80'
            }
        }

    }

    post {
        success {
            echo '''
==============================================
  PIPELINE REUSSI - Application deployee !
  Frontend : http://localhost
  API      : http://localhost:5000/api/health
==============================================
            '''
        }
        failure {
            echo '''
==============================================
  PIPELINE ECHOUE
  Consultez les logs ci-dessus
==============================================
            '''
        }
        always {
            sh 'docker ps --format "table {{.Names}}\\t{{.Status}}\\t{{.Ports}}" || true'
            echo '=== Fin du pipeline ==='
        }
    }
}
