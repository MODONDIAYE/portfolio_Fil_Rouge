pipeline {
    agent any

    environment {
        PROJECT_DIR = 'Express_MongoDB_V6'
        DOCKERHUB_USER = 'modoundiaye'
        BACKEND_IMAGE = 'modoundiaye/portfolio-backend'
        FRONTEND_IMAGE = 'modoundiaye/portfolio-frontend'
    }

    triggers {
        githubPush()
    }

    options {
        timeout(time: 20, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '5'))
    }

    stages {

        // ETAPE 1 : Checkout
        // Recupere le code source depuis GitHub via la config Git du job Jenkins.
        // checkout scm utilise l URL, la branche et les credentials du job.
        // env.GIT_COMMIT = hash SHA du commit (.take(7) = 7 premiers caracteres).
        stage('Checkout') {
            steps {
                echo '=== ETAPE 1 : Recuperation du code source depuis GitHub ==='
                checkout scm
                echo "=== Commit : ${env.GIT_COMMIT?.take(7)} ==="
            }
        }

        // ETAPE 2 : Verification
        // Verifie que Docker est disponible dans le conteneur Jenkins.
        // Node.js n est PAS installe dans Jenkins : le build se fait DANS les images Docker.
        // On affiche aussi le contenu du workspace pour diagnostiquer les chemins.
        stage('Verification') {
            steps {
                echo '=== ETAPE 2 : Verification de l environnement Docker ==='
                sh 'docker --version'
                sh 'docker compose version'
                // Affiche le contenu du workspace pour verifier que docker-compose.yml est present
                sh "ls -la ${WORKSPACE}//"
                sh 'docker ps --format "table {{.Names}}\\t{{.Status}}"'
            }
        }

        // ETAPE 3 : Docker Build
        // Construit les images Docker pour le backend et le frontend.
        // docker compose build lit le docker-compose.yml et construit :
        //   - Backend  : node:20-alpine + Express.js
        //   - Frontend : node:20-alpine (npm run build) + nginx:alpine (sert dist/)
        //
        // IMPORTANT : on utilise -f avec le chemin ABSOLU vers docker-compose.yml
        // car Docker cherche le fichier depuis son propre contexte, pas depuis
        // le repertoire courant du shell Jenkins.
        // WORKSPACE est la variable Jenkins contenant le chemin absolu du workspace.
        stage('Docker Build') {
            steps {
                echo '=== ETAPE 3 : Construction des images Docker ==='
                sh "docker compose -f ${WORKSPACE}/${PROJECT_DIR}/docker-compose.yml build"
                echo '=== Images construites avec succes ==='
            }
        }

        // ETAPE 4 : Push Docker Hub
        // Tag les images buildees et les pousse vers Docker Hub.
        // Utilise un credential Jenkins 'dockerhub-credentials' (Username/Password).
        stage('Push Docker Hub') {
            steps {
                echo '=== ETAPE 4 : Push des images vers Docker Hub ==='
                withCredentials([usernamePassword(credentialsId: 'dockerhub-credentials', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                    sh '''
                        echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin
                        docker tag express_mongodb_v6-backend:latest ${BACKEND_IMAGE}:latest
                        docker tag express_mongodb_v6-backend:latest ${BACKEND_IMAGE}:${BUILD_NUMBER}
                        docker tag express_mongodb_v6-frontend:latest ${FRONTEND_IMAGE}:latest
                        docker tag express_mongodb_v6-frontend:latest ${FRONTEND_IMAGE}:${BUILD_NUMBER}
                        docker push ${BACKEND_IMAGE}:latest
                        docker push ${BACKEND_IMAGE}:${BUILD_NUMBER}
                        docker push ${FRONTEND_IMAGE}:latest
                        docker push ${FRONTEND_IMAGE}:${BUILD_NUMBER}
                        docker logout
                    '''
                }
                echo '=== Images poussees vers Docker Hub ==='
            }
        }

        // ETAPE 5 : Deploiement
        // Arrete les anciens conteneurs et demarre les nouveaux (Rolling Update).
        // docker compose down  -> arrete les conteneurs (volume MongoDB conserve)
        // docker compose up -d -> demarre les nouveaux en arriere-plan
        // || true : evite une erreur si aucun conteneur ne tourne (1er deploiement)
        // sleep 30 : attend que MongoDB soit healthy et que le backend se connecte
        // Conteneurs : portfolio_mongodb (27017), portfolio_backend (5000), portfolio_frontend (80)
        stage('Deploiement') {
            steps {
                echo '=== ETAPE 5 : Deploiement des conteneurs ==='
                echo '    Arret des anciens conteneurs...'
                sh "docker compose -f ${WORKSPACE}/${PROJECT_DIR}/docker-compose.yml down || true"
                echo '    Demarrage des nouveaux conteneurs (-d = arriere-plan)...'
                sh "docker compose -f ${WORKSPACE}/${PROJECT_DIR}/docker-compose.yml up -d"
                echo '    Attente demarrage MongoDB + Backend (30s)...'
                sh 'sleep 30'
            }
        }

        // ETAPE 6 : Health Check
        // Verifie que l application repond apres le deploiement.
        //
        // IMPORTANT : Jenkins tourne dans son propre conteneur Docker.
        // "localhost" dans Jenkins ne pointe PAS vers le backend.
        // On utilise "docker exec" pour executer curl DEPUIS le conteneur backend
        // lui-meme, ce qui garantit que l API est bien accessible.
        //
        // docker exec portfolio_backend curl -f http://localhost:5000/api/health
        //   -> execute curl a l interieur du conteneur portfolio_backend
        //   -> localhost:5000 est valide DANS ce conteneur
        stage('Health Check') {
            steps {
                echo '=== ETAPE 6 : Verification de l application ==='
                echo '    Test API Backend (depuis le conteneur portfolio_backend)...'
                sh 'docker exec portfolio_backend wget --spider -q http://127.0.0.1:5000/api/health'
                echo '    Test Frontend React (depuis le conteneur portfolio_frontend)...'
                sh '''
                    for i in 1 2 3 4 5; do
                        docker exec portfolio_frontend wget --spider -q http://127.0.0.1:80 && exit 0
                        echo "    Tentative $i echouee, retry dans 5s..."
                        sleep 5
                    done
                    exit 1
                '''
                echo '=== Application operationnelle ==='
            }
        }

    }

    // post : actions apres la fin du pipeline
    // success : tous les stages ont reussi
    // failure : au moins un stage a echoue
    // always  : execute dans tous les cas (affiche l etat des conteneurs)
    post {
        success {
            echo '=== PIPELINE REUSSI - Application deployee ! Frontend: http://localhost | API: http://localhost:5000/api/health ==='
            mail to: 'mn2243d@gmail.com',
                 subject: "✅ Jenkins - Build SUCCESS : ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                 body: """Le pipeline ${env.JOB_NAME} a réussi.

Commit : ${env.GIT_COMMIT?.take(7)}
Build  : ${env.BUILD_URL}

Application déployée :
- Frontend : http://localhost
- API      : http://localhost:5000/api/health
"""
        }
        failure {
            echo '=== PIPELINE ECHOUE - Consultez les logs ci-dessus pour identifier le stage en erreur ==='
            mail to: 'mn2243d@gmail.com',
                 subject: "❌ Jenkins - Build FAILED : ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                 body: """Le pipeline ${env.JOB_NAME} a échoué.

Commit : ${env.GIT_COMMIT?.take(7)}
Build  : ${env.BUILD_URL}

Consultez les logs pour identifier l'erreur.
"""
        }
        always {
            sh 'docker ps --format "table {{.Names}}\\t{{.Status}}\\t{{.Ports}}" || true'
            echo '=== Fin du pipeline ==='
        }
    }
}