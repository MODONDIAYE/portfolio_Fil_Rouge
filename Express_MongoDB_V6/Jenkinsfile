pipeline {
    agent any
    environment {
        PROJECT_DIR    = 'Express_MongoDB_V6'
        BACKEND_IMAGE  = 'modoundiaye/portfolio-backend'
        FRONTEND_IMAGE = 'modoundiaye/portfolio-frontend'
    }
    triggers { githubPush() }
    options {
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '5'))
    }
    stages {
        stage('Checkout') {
            steps {
                echo '=== ETAPE 1 : Checkout ==='
                checkout scm
                echo "=== Commit : ${env.GIT_COMMIT?.take(7)} ==="
            }
        }
        stage('Verification') {
            steps {
                echo '=== ETAPE 2 : Verification Docker ==='
                sh 'docker --version'
                sh 'docker compose version'
                sh 'docker ps --format "table {{.Names}}\\t{{.Status}}"'
            }
        }
        stage('Tests') {
            steps {
                dir("${PROJECT_DIR}/backend-expressJS") {
                    echo '=== ETAPE 3 : Tests Jest ==='
                    sh 'npm install'
                    sh 'npm run test:coverage || true'
                    echo '=== Tests termines ==='
                }
            }
        }
        stage('SonarQube Analysis') {
            steps {
                dir("${PROJECT_DIR}") {
                    echo '=== ETAPE 4 : Analyse SonarQube ==='
                    // script{} est obligatoire pour utiliser def en Declarative Pipeline
                    script {
                        withSonarQubeEnv('SonarQube-Local') {
                            def scannerHome = tool 'SonarScanner'
                            sh "${scannerHome}/bin/sonar-scanner -Dsonar.projectKey=portfolio-v6 -Dsonar.sources=backend-expressJS,frontend-react/src -Dsonar.exclusions=**/node_modules/**,**/dist/**,**/coverage/** -Dsonar.javascript.lcov.reportPaths=backend-expressJS/coverage/lcov.info -Dsonar.sourceEncoding=UTF-8"
                        }
                    }
                    echo '=== Analyse SonarQube terminee ==='
                }
            }
        }
        stage('Quality Gate') {
            steps {
                echo '=== ETAPE 5 : Quality Gate ==='
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
                echo '=== Quality Gate : PASSED ==='
            }
        }
        stage('Docker Build') {
            steps {
                dir("${PROJECT_DIR}") {
                    echo '=== ETAPE 6 : Docker Build ==='
                    sh 'docker compose build'
                    echo '=== Images construites ==='
                }
            }
        }
        stage('Deploiement') {
            steps {
                dir("${PROJECT_DIR}") {
                    echo '=== ETAPE 7 : Deploiement ==='
                    sh 'docker compose down || true'
                    sh 'docker compose up -d'
                    sh 'sleep 25'
                }
            }
        }
        stage('Health Check') {
            steps {
                echo '=== ETAPE 8 : Health Check ==='
                sh 'docker exec portfolio_backend wget --spider -q http://127.0.0.1:5000/api/health'
                echo '=== Application operationnelle ==='
            }
        }
    }
    post {
        success { echo '=== PIPELINE REUSSI ===' }
        failure { echo '=== PIPELINE ECHOUE ===' }
        always {
            sh 'docker ps --format "table {{.Names}}\\t{{.Status}}" || true'
            echo '=== Fin du pipeline ==='
        }
    }
}