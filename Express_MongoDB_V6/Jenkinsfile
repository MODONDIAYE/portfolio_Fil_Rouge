/*
 * ============================================================
 *  JENKINSFILE — Pipeline CI/CD Portfolio Modou NDIAYE V6
 * ============================================================
 *  Projet   : Express_MongoDB_V6
 *  Stack    : Express.js · React · MongoDB · Docker
 *  Dépôt    : https://github.com/MODONDIAYE/portfolio_Fil_Rouge
 *  Auteur   : Modou NDIAYE
 *
 *  Ce pipeline automatise le cycle de vie complet de l application :
 *  1. Récupération du code source depuis GitHub
 *  2. Vérification de l environnement Docker
 *  3. Construction des images Docker (backend + frontend)
 *  4. Déploiement des conteneurs via docker compose
 *  5. Vérification que l application répond correctement
 *
 *  Déclenchement : manuel (Build Now) ou automatique via webhook GitHub
 * ============================================================
 */

pipeline {

    /*
     * agent any
     * Jenkins peut exécuter ce pipeline sur n importe quel agent disponible.
     * Dans notre cas : le conteneur jenkins_portfolio.
     */
    agent any

    /*
     * environment { }
     * Variables d environnement disponibles dans tout le pipeline.
     * PROJECT_DIR pointe vers le sous-dossier de l application fullstack.
     */
    environment {
        PROJECT_DIR = 'Express_MongoDB_V6'
    }

    /*
     * options { }
     * - timeout     : arrête le pipeline après 20 min (évite les builds bloqués)
     * - buildDiscarder : conserve uniquement les 5 derniers builds (économise l espace)
     */
    options {
        timeout(time: 20, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '5'))
    }

    stages {

        /*
         * STAGE 1 — Checkout
         * Récupère le code source depuis GitHub.
         * "checkout scm" utilise la config Git du job Jenkins (URL, branche, credentials).
         * env.GIT_COMMIT contient le hash SHA du commit (.take(7) = 7 premiers caractères).
         */
        stage('Checkout') {
            steps {
                echo '=== ETAPE 1 : Recuperation du code source depuis GitHub ==='
                checkout scm
                echo "=== Commit recupere : ${env.GIT_COMMIT?.take(7)} ==="
            }
        }

        /*
         * STAGE 2 — Verification
         * Vérifie que Docker est disponible dans le conteneur Jenkins.
         * Node.js n est PAS nécessaire ici : le build se fait DANS les images Docker.
         * "docker ps" liste les conteneurs actifs avant le déploiement.
         */
        stage('Verification') {
            steps {
                echo '=== ETAPE 2 : Verification de l environnement Docker ==='
                sh 'docker --version'
                sh 'docker compose version'
                sh 'docker ps --format "table {{.Names}}\\t{{.Status}}"'
            }
        }

        /*
         * STAGE 3 — Docker Build
         * Construit les images Docker pour le backend et le frontend.
         *
         * docker compose build lit le docker-compose.yml et construit :
         *   - Backend  : node:20-alpine + Express.js (npm install + node server.js)
         *   - Frontend : node:20-alpine (npm run build) + nginx:alpine (sert dist/)
         *
         * Le cache Docker est utilisé : si le code n a pas changé, la couche
         * est réutilisée → build plus rapide.
         *
         * dir("${PROJECT_DIR}") se place dans Express_MongoDB_V6/
         * où se trouve le docker-compose.yml.
         */
        stage('Docker Build') {
            steps {
                dir("${PROJECT_DIR}") {
                    echo '=== ETAPE 3 : Construction des images Docker ==='
                    echo '    Backend  : node:20-alpine + Express.js'
                    echo '    Frontend : node:20-alpine (build) + nginx:alpine (serve)'
                    sh 'docker compose build'
                    echo '=== Images Docker construites avec succes ==='
                }
            }
        }

        /*
         * STAGE 4 — Deploiement
         * Arrête les anciens conteneurs et démarre les nouveaux.
         *
         * Stratégie Rolling Update :
         *   1. docker compose down  → arrête les conteneurs (volume MongoDB conservé)
         *   2. docker compose up -d → démarre les nouveaux en arrière-plan (-d)
         *
         * "|| true" : évite une erreur si aucun conteneur ne tourne (1er déploiement).
         *
         * "sleep 25" : MongoDB met ~10-15s à démarrer et passer le healthcheck.
         * Le backend attend que MongoDB soit healthy avant de se connecter.
         * On attend 25s pour garantir que tout est prêt avant le health check.
         *
         * Conteneurs démarrés :
         *   - portfolio_mongodb  (port 27017) : base de données
         *   - portfolio_backend  (port 5000)  : API Express.js
         *   - portfolio_frontend (port 80)    : React servi par Nginx
         */
        stage('Deploiement') {
            steps {
                dir("${PROJECT_DIR}") {
                    echo '=== ETAPE 4 : Deploiement des conteneurs ==='

                    echo '    Arret des anciens conteneurs...'
                    sh 'docker compose down || true'

                    echo '    Demarrage des nouveaux conteneurs (-d = arriere-plan)...'
                    sh 'docker compose up -d'

                    echo '    Attente du demarrage complet (25 secondes)...'
                    sh 'sleep 25'
                }
            }
        }

        /*
         * STAGE 5 — Health Check
         * Vérifie que l application est opérationnelle après le déploiement.
         *
         * Test 1 — API Backend :
         *   curl -f http://localhost:5000/api/health
         *   -f : retourne une erreur si le code HTTP n est pas 2xx
         *   Réponse attendue : { status: "OK", message: "API operationnelle" }
         *
         * Test 2 — Frontend :
         *   curl -f -s -o /dev/null -w "HTTP Status: %{http_code}" http://localhost:80
         *   -s : mode silencieux
         *   -o /dev/null : ignore le contenu HTML
         *   -w "%{http_code}" : affiche uniquement le code HTTP (200 = OK)
         *
         * Si un test échoue → pipeline FAILURE → notification envoyée.
         */
        stage('Health Check') {
            steps {
                echo '=== ETAPE 5 : Verification de l application ==='

                echo '    Test API Backend (port 5000)...'
                sh 'curl -f http://localhost:5000/api/health'

                echo '    Test Frontend React via Nginx (port 80)...'
                sh 'curl -f -s -o /dev/null -w "HTTP Status: %{http_code}" http://localhost:80'

                echo '=== Application operationnelle ==='
            }
        }

    }

    /*
     * post { }
     * Actions exécutées APRÈS la fin du pipeline.
     *
     * success : tous les stages ont réussi
     * failure : au moins un stage a échoué
     * always  : exécuté dans tous les cas (affiche l état des conteneurs)
     */
    post {

        success {
            echo '''
==============================================
  PIPELINE REUSSI - Application deployee !
  Frontend : http://localhost
  API      : http://localhost:5000/api/health
  MongoDB  : localhost:27017
==============================================
            '''
        }

        failure {
            echo '''
==============================================
  PIPELINE ECHOUE
  Consultez les logs ci-dessus pour identifier
  le stage en erreur et corriger le probleme.
==============================================
            '''
        }

        always {
            // Affiche l etat final de tous les conteneurs pour diagnostic
            sh 'docker ps --format "table {{.Names}}\\t{{.Status}}\\t{{.Ports}}" || true'
            echo '=== Fin du pipeline ==='
        }
    }
}
