pipeline {
    agent any

    environment {
        PROJECT_DIR = 'Express_MongoDB_V6'
    }

    options {
        timeout(time: 20, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '5'))
    }

    stages {

        // ETAPE 1 : Checkout
        // Recupere le code source depuis GitHub via la config Git du job Jenkins.
        // checkout scm utilise l URL, la branche et les credentials du job.
        // env.GIT_COMMIT = hash SHA du commit (.take(7) = 7 premiers caracteres).
        stage('Checkout') {
            steps {
                echo '=== ETAPE 1 : Recuperation du code source depuis GitHub ==='
                checkout scm
                echo "=== Commit : ${env.GIT_COMMIT?.take(7)} ==="
            }
        }

        // ETAPE 2 : Verification
        // Verifie que Docker est disponible dans le conteneur Jenkins.
        // Node.js n est PAS installe dans Jenkins : le build se fait DANS les images Docker.
        // Jenkins n a besoin que de Docker pour orchestrer le deploiement.
        stage('Verification') {
            steps {
                echo '=== ETAPE 2 : Verification de l environnement Docker ==='
                sh 'docker --version'
                sh 'docker compose version'
                sh 'docker ps --format "table {{.Names}}\\t{{.Status}}"'
            }
        }

        // ETAPE 3 : Docker Build
        // Construit les images Docker pour le backend et le frontend.
        // docker compose build lit le docker-compose.yml et construit :
        //   - Backend  : node:20-alpine + Express.js
        //   - Frontend : node:20-alpine (npm run build) + nginx:alpine (sert dist/)
        // Le cache Docker est utilise si le code n a pas change -> build plus rapide.
        // dir(PROJECT_DIR) se place dans Express_MongoDB_V6/ ou est le docker-compose.yml.
        stage('Docker Build') {
            steps {
                dir("") {
                    echo '=== ETAPE 3 : Construction des images Docker ==='
                    sh 'docker compose build'
                    echo '=== Images construites avec succes ==='
                }
            }
        }

        // ETAPE 4 : Deploiement
        // Arrete les anciens conteneurs et demarre les nouveaux (Rolling Update).
        // docker compose down  -> arrete les conteneurs (volume MongoDB conserve)
        // docker compose up -d -> demarre les nouveaux en arriere-plan
        // || true : evite une erreur si aucun conteneur ne tourne (1er deploiement)
        // sleep 25 : attend que MongoDB soit healthy et que le backend se connecte
        // Conteneurs : portfolio_mongodb (27017), portfolio_backend (5000), portfolio_frontend (80)
        stage('Deploiement') {
            steps {
                dir("") {
                    echo '=== ETAPE 4 : Deploiement des conteneurs ==='
                    echo '    Arret des anciens conteneurs...'
                    sh 'docker compose down || true'
                    echo '    Demarrage des nouveaux conteneurs (-d = arriere-plan)...'
                    sh 'docker compose up -d'
                    echo '    Attente demarrage MongoDB + Backend (25s)...'
                    sh 'sleep 25'
                }
            }
        }

        // ETAPE 5 : Health Check
        // Verifie que l application repond apres le deploiement.
        //
        // IMPORTANT : Jenkins tourne dans son propre conteneur Docker.
        // "localhost" dans Jenkins ne pointe PAS vers le backend.
        // On utilise "docker exec" pour executer curl DEPUIS le conteneur backend
        // lui-meme, ce qui garantit que l API est bien accessible.
        //
        // docker exec portfolio_backend curl -f http://localhost:5000/api/health
        //   -> execute curl a l interieur du conteneur portfolio_backend
        //   -> localhost:5000 est valide DANS ce conteneur
        //
        // docker exec portfolio_frontend curl -f http://localhost:80
        //   -> execute curl a l interieur du conteneur portfolio_frontend (Nginx)
        //   -> verifie que Nginx sert bien les fichiers React
        stage('Health Check') {
            steps {
                echo '=== ETAPE 5 : Verification de l application ==='

                // Test API : curl execute DANS le conteneur backend
                echo '    Test API Backend (depuis le conteneur portfolio_backend)...'
                sh 'docker exec portfolio_backend curl -f http://localhost:5000/api/health'

                // Test Frontend : curl execute DANS le conteneur frontend (Nginx)
                echo '    Test Frontend React (depuis le conteneur portfolio_frontend)...'
                sh 'docker exec portfolio_frontend curl -f -s -o /dev/null -w "HTTP Status: %{http_code}" http://localhost:80'

                echo '=== Application operationnelle ==='
            }
        }

    }

    // post : actions apres la fin du pipeline
    // success : tous les stages ont reussi
    // failure : au moins un stage a echoue
    // always  : execute dans tous les cas (affiche l etat des conteneurs)
    post {
        success {
            echo '=== PIPELINE REUSSI - Application deployee ! Frontend: http://localhost | API: http://localhost:5000/api/health ==='
        }
        failure {
            echo '=== PIPELINE ECHOUE - Consultez les logs ci-dessus pour identifier le stage en erreur ==='
        }
        always {
            sh 'docker ps --format "table {{.Names}}\\t{{.Status}}\\t{{.Ports}}" || true'
            echo '=== Fin du pipeline ==='
        }
    }
}