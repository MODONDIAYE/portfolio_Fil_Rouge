{
  "name": "portfolio-modou-ndiaye",
  "version": "1.0.0",
  "description": "Portfolio professionnel de Modou NDIAYE - Développeur Fullstack & UI Designer",
  "main": "src/main.js",
  "scripts": {
    "dev": "npx live-server --port=3000 --open=/index.html",
    "build:css": "npx tailwindcss -i ./src/css/input.css -o ./src/css/output.css --minify",
    "watch:css": "npx tailwindcss -i ./src/css/input.css -o ./src/css/output.css --watch",
    "start": "npm run build:css && npm run dev"
  },
  "keywords": ["portfolio", "fullstack", "javascript", "tailwindcss"],
  "author": "Modou NDIAYE",
  "license": "MIT",
  "devDependencies": {
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "live-server": "^1.2.2"
  }
}
